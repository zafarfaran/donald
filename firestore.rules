rules_version = '2';

// Donald API uses the Firebase Admin SDK (service account) — it bypasses these rules.
// These rules apply only if you use the Firestore *client* SDK in a browser or mobile app.
//
// Default: deny all direct client access. Data is written/read only by your backend.
// Deploy: firebase deploy --only firestore:rules   (from this folder, after firebase login & firebase use heyitdonald)

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
