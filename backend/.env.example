# Copy to .env in this folder (donald/backend/.env)

# Firecrawl — live search for salary, tuition, job market, AI risk snippets
# https://firecrawl.dev → dashboard → API keys
FIRECRAWL_API_KEY=

# Optional tuning (voice research runs many searches in parallel):
# FIRECRAWL_HTTP_TIMEOUT_SEC=75
# FIRECRAWL_SEARCH_TIMEOUT_MS=55000
# FIRECRAWL_MAX_CONCURRENT=5
# RESEARCH_MAX_QUERIES=10
# VOICE_RESEARCH_DEADLINE_SEC=270
# ANTHROPIC_TIMEOUT_SEC=180
#
# Credits / cost (defaults are now tuned for lower spend):
# FIRECRAWL_RESULTS_PER_QUERY=3   # default 3 — lower this further for cheaper runs
# RESEARCH_FIRECRAWL_SCRAPE=false # default false — markdown scraping is richer but costs more
# RESEARCH_MAX_QUERIES=10         # default 10 (fallback pipeline only; agentic mode ignores this)
# RESEARCH_MAX_SEARCH_CALLS=6     # max web searches Claude can run in agentic mode (default 6)

# Anthropic (Claude) — required for research extraction, AI risk analysis, and tips
# https://console.anthropic.com → API keys
# Uses claude-3-5-haiku (~$0.001–0.003 per session)
# Required for this pipeline. If unset, research requests fail.
ANTHROPIC_API_KEY=

# Optional: override structured-analysis model (default claude-haiku-4-5). Older claude-3-5-haiku-latest may 404.
# ANTHROPIC_ANALYSIS_MODEL=claude-haiku-4-5-20251001
# Optional: enable prompt caching for Claude requests (default true).
# ANTHROPIC_PROMPT_CACHING=true

# Optional: deployed frontend origin for CORS (local dev already allowed)
FRONTEND_URL=http://localhost:3000

# ElevenLabs — only if the agent is NOT public (needs server-minted WebRTC token)
# https://elevenlabs.io → profile / API keys → create key (never commit it)
# ELEVENLABS_API_KEY=

# ── Production: Firestore (Google Cloud) ──
# Set project id and use Application Default Credentials, or GOOGLE_APPLICATION_CREDENTIALS to a JSON key file.
# FIRESTORE_DISABLED=1
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Or: FIRESTORE_PROJECT_ID=your-gcp-project-id
# Service account: either a file path, or paste the full JSON (Railway / some hosts):
# GOOGLE_APPLICATION_CREDENTIALS=your-project-firebase-adminsdk-xxxxx.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# ── Redis (Celery broker, rate limits, cache) ──
# If REDIS_URL is unset, Redis is not used (in-memory rate limits). Set explicitly for local Redis:
# REDIS_URL=redis://localhost:6379/0
# REDIS_DISABLED=1
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# CELERY_DISABLED=1

# ── Observability ──
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-collector/v1/traces
# OTEL_SERVICE_NAME=donald-api
# OTEL_SDK_DISABLED=1
# ENVIRONMENT=development

# ── Security / ops ──
# TRUSTED_HOSTS=api.yourdomain.com
# RATE_LIMIT_DISABLED=1
# RATE_LIMIT_WEBHOOK_PER_MIN=20
# RATE_LIMIT_WEBHOOK_RESEARCH_PER_MIN=6
# RESEARCH_MAX_INFLIGHT_PER_IP=2
# RESEARCH_MAX_INFLIGHT_PER_SESSION=1
# RESEARCH_INFLIGHT_TTL_SEC=900
# RESEARCH_CONCURRENCY_DISABLED=1
# ACTIVITY_TRACKING_DISABLED=1
# MAX_REQUEST_BODY_BYTES=1048576
# LOG_JSON=true
# LOG_LEVEL=INFO

# Restrict ElevenLabs token minting to your own agent ids:
# ELEVENLABS_ALLOWED_AGENT_IDS=agent_xxx,agent_yyy
# Or a single fixed id:
# ELEVENLABS_AGENT_ID=agent_xxx
